    {
      "name": "slack",
      "displayName": "Slack",
      "description": "Send and read Slack messages",
      "runtime": "node",
      "homepage": "https://github.com/modelcontextprotocol/slack",
      "install": {
        "command": "npm install -g @anthropic/mcp-slack",
